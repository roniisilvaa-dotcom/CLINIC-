# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: connection string do Neon Postgres.
DATABASE_URL="postgres://user:password@host/db"

# ── WhatsApp — Meta Cloud API (oficial) ───────────────────────────────
# Token de acesso permanente (System User) do app Meta da clínica.
META_WHATSAPP_TOKEN="EAAG..."
# ID do número de telefone registrado no WhatsApp Manager (não é o número em si).
META_PHONE_NUMBER_ID="123456789012345"
# App Secret do app Meta — usado para validar a assinatura (X-Hub-Signature-256) de cada webhook.
META_APP_SECRET="minha_app_secret"
# String arbitrária definida por você. Usada só na etapa de verificação do webhook no painel Meta.
META_VERIFY_TOKEN="uma-string-secreta-que-voce-escolhe"
# Opcional — versão da Graph API (default v21.0)
META_GRAPH_VERSION="v21.0"

# WhatsApp da Dra. Mariah (com DDI), pra receber notificação de cada novo agendamento.
WHATSAPP_DRA="5544999990000"

# ── Pagamentos — Asaas (Pix) ──────────────────────────────────────────
ASAAS_API_KEY="$aact_..."
# "true" usa o ambiente sandbox.asaas.com; deixe em branco/false pra produção.
ASAAS_SANDBOX="false"

# ── Legado (Z-API) ────────────────────────────────────────────────────
# Não utilizado mais desde a migração pra Meta Cloud API oficial.
# Mantido comentado só como referência caso precise reverter no futuro.
# ZAPI_BASE_URL="https://api.z-api.io/instances/SUA_INSTANCIA/token/SEU_TOKEN"
# ZAPI_TOKEN="seu-client-token"
